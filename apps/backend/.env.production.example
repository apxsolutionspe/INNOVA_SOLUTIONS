NODE_ENV=production
PORT=3000
DATABASE_URL=
JWT_SECRET=
JWT_EXPIRES_IN=1d
FRONTEND_URL=
CORS_ORIGIN=
PUBLIC_APP_URL=https://innova-solutions-uqbx.onrender.com
SWAGGER_ENABLED=false

JSONPE_BASE_URL=https://api.json.pe/api
JSONPE_TOKEN=
JSONPE_TIMEOUT_MS=30000

# IA Cloud para Render
AI_ENABLED=true
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=
OPENAI_API_KEY=
AI_TIMEOUT_MS=30000
AI_MAX_CONTEXT_ITEMS=10
AI_MAX_OUTPUT_TOKENS=500
AI_CACHE_TTL_SECONDS=300
AI_USE_CACHE=true

# IA local opcional para desarrollo, no requerida en Render
AI_LOCAL_ENABLED=false
AI_LOCAL_SERVICE_URL=
AI_LOCAL_TIMEOUT_MS=60000
AI_LOCAL_MODE=local
AI_LOCAL_ALLOW_REBUILD_INDEX=false

# Integraciones externas
SUNAT_MODE=mock
WHATSAPP_MODE=mock
WHATSAPP_ENABLED=false
WHATSAPP_API_VERSION=v25.0
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_DEFAULT_COUNTRY_CODE=51
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_SEND_STRATEGY=link
WHATSAPP_TEMPLATE_RECEIPT=
WHATSAPP_UPLOAD_MEDIA=true
WHATSAPP_FALLBACK_TO_LINK=true
CULQI_MODE=mock
IZIPAY_MODE=mock
ECOMMERCE_MODE=mock
