NODE_ENV=production
PORT=3000
DATABASE_URL=
JWT_SECRET=
JWT_EXPIRES_IN=1d
FRONTEND_URL=
CORS_ORIGIN=
SWAGGER_ENABLED=false

JSONPE_BASE_URL=https://api.json.pe/api
JSONPE_TOKEN=
JSONPE_TIMEOUT_MS=30000

# IA Cloud para Render
AI_ENABLED=true
AI_PROVIDER=openai
AI_MODEL=gpt-4.1-mini
OPENAI_API_KEY=
AI_TIMEOUT_MS=30000
AI_MAX_CONTEXT_ITEMS=20

# IA local opcional para desarrollo, no requerida en Render
AI_LOCAL_ENABLED=false
AI_LOCAL_SERVICE_URL=
AI_LOCAL_TIMEOUT_MS=60000
AI_LOCAL_MODE=local
AI_LOCAL_ALLOW_REBUILD_INDEX=false

# Integraciones externas
SUNAT_MODE=mock
WHATSAPP_MODE=mock
CULQI_MODE=mock
IZIPAY_MODE=mock
ECOMMERCE_MODE=mock
