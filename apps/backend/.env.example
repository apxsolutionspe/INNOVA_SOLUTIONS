WHATSAPP_API_VERSION=v25.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_SEND_STRATEGY=receipt_pdf
WHATSAPP_TEMPLATE_LANGUAGE=es_PE
WHATSAPP_TEMPLATE_TEST_NAME=hello_world
WHATSAPP_TEMPLATE_TEST_LANGUAGE=en_US
WHATSAPP_RECEIPT_TEMPLATE_NAME=comprobante_venta
WHATSAPP_RECEIPT_PDF_TEMPLATE_NAME=comprobante_pdf
WHATSAPP_RECEIPT_TEMPLATE_LANGUAGE=es_PE

# CULQI
CULQI_MODE=mock
CULQI_API_URL=https://api.culqi.com
CULQI_PUBLIC_KEY=
CULQI_PRIVATE_KEY=

# IZIPAY
