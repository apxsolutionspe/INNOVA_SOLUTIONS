AI_MAX_CONTEXT_ITEMS=20

# Compatibilidad con proveedores anteriores
AI_MODE=mock
AI_API_KEY=

# AI LOCAL
AI_LOCAL_ENABLED=true
AI_LOCAL_SERVICE_URL=http://localhost:8001
AI_LOCAL_TIMEOUT_MS=60000
AI_LOCAL_MODE=local
AI_LOCAL_ALLOW_REBUILD_INDEX=true

# ECOMMERCE
