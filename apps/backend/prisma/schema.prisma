generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(uuid())
  fullName    String
  email       String    @unique
  password    String
  roleId      String
  role        Role      @relation(fields: [roleId], references: [id])
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  auditLogs   AuditLog[]
  inventoryMovements InventoryMovement[]
  sales       Sale[]
  saleCancellations SaleCancellation[]
  serviceOrders ServiceOrder[]
  serviceOrderLogs ServiceOrderLog[]
  cashSessions CashSession[]
  cashMovements CashMovement[]
  quickServiceSales QuickServiceSale[]
  purchaseOrders PurchaseOrder[]
  notifications Notification[]
  whatsappMessageLogs WhatsappMessageLog[]

  @@index([roleId])
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  module    String?
  description String?
  entityId  String?
  entityType String?
  ipAddress String?
  userAgent String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([module])
  @@index([action])
  @@index([createdAt])
}

model Customer {
  id             String       @id @default(uuid())
  customerType   CustomerType @default(NATURAL)
  documentType   DocumentType
  documentNumber String
  fullName       String
  firstName      String?
  lastName       String?
  businessName   String?
  tradeName      String?
  legalRepresentative String?
  phone          String?
  email          String?
  address        String?
  businessLine   String?
  notes          String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  sales          Sale[]
  serviceOrders  ServiceOrder[]
  quickServiceSales QuickServiceSale[]

  @@unique([documentType, documentNumber])
  @@index([customerType])
  @@index([fullName])
  @@index([phone])
}

model ProductCategory {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
  id             String              @id @default(uuid())
  name           String
  description    String?
  sku            String              @unique
  barcode        String?             @unique
  imageUrl       String?
  categoryId     String
  category       ProductCategory     @relation(fields: [categoryId], references: [id])
  purchasePrice  Decimal             @db.Decimal(12, 2)
  salePrice      Decimal             @db.Decimal(12, 2)
  stock          Int                 @default(0)
  minStock       Int                 @default(0)
  unit           String
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  movements      InventoryMovement[]
  saleItems      SaleItem[]
  serviceOrderItems ServiceOrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
  onlineOrderItems OnlineOrderItem[]
  supplierProducts SupplierProduct[]

  @@index([categoryId])
  @@index([name])
}

model InventoryMovement {
  id            String                @id @default(uuid())
  productId     String
  product       Product               @relation(fields: [productId], references: [id])
  type          InventoryMovementType
  quantity      Int
  previousStock Int
  newStock      Int
  reason        String
  userId        String?
  user          User?                 @relation(fields: [userId], references: [id])
  createdAt     DateTime              @default(now())

  @@index([productId])
  @@index([userId])
}

enum DocumentType {
  DNI
  RUC
  CE
  PASSPORT
  OTHER
}

enum CustomerType {
  NATURAL
  COMPANY
}

enum InventoryMovementType {
  IN
  OUT
  ADJUSTMENT
}

model Sale {
  id            String             @id @default(uuid())
  code          String             @unique
  customerId    String?
  customer      Customer?          @relation(fields: [customerId], references: [id])
  userId        String
  user          User               @relation(fields: [userId], references: [id])
  subtotal      Decimal            @db.Decimal(12, 2)
  discountTotal Decimal            @db.Decimal(12, 2)
  taxTotal      Decimal            @db.Decimal(12, 2)
  total         Decimal            @db.Decimal(12, 2)
  applyIgv      Boolean            @default(false)
  igvRate       Decimal            @default(0.18) @db.Decimal(5, 4)
  paymentStatus PaymentStatus
  status        SaleStatus         @default(COMPLETED)
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  items         SaleItem[]
  payments      Payment[]
  cancellations SaleCancellation[]
  cashMovements CashMovement[]
  sunatDocuments SunatDocument[]
  paymentTransactions PaymentTransaction[]

  @@index([customerId])
  @@index([userId])
  @@index([createdAt])
}

model SaleItem {
  id          String       @id @default(uuid())
  saleId      String
  sale        Sale         @relation(fields: [saleId], references: [id])
  productId   String?
  product     Product?     @relation(fields: [productId], references: [id])
  itemType    SaleItemType
  description String
  quantity    Int
  unitPrice   Decimal      @db.Decimal(12, 2)
  discount    Decimal      @db.Decimal(12, 2)
  subtotal    Decimal      @db.Decimal(12, 2)
  total       Decimal      @db.Decimal(12, 2)
  createdAt   DateTime     @default(now())

  @@index([saleId])
  @@index([productId])
}

model Payment {
  id        String        @id @default(uuid())
  saleId    String
  sale      Sale          @relation(fields: [saleId], references: [id])
  method    PaymentMethod
  amount    Decimal       @db.Decimal(12, 2)
  reference String?
  createdAt DateTime      @default(now())

  @@index([saleId])
}

model SaleCancellation {
  id        String   @id @default(uuid())
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  reason    String
  createdAt DateTime @default(now())

  @@index([saleId])
  @@index([userId])
}

enum SaleStatus {
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PAID
  PARTIAL
  PENDING
}

enum PaymentMethod {
  CASH
  YAPE
  PLIN
  TRANSFER
  MIXED
}

enum SaleItemType {
  PRODUCT
  SERVICE
}

model ServiceOrder {
  id                    String              @id @default(uuid())
  code                  String              @unique
  customerId            String
  customer              Customer            @relation(fields: [customerId], references: [id])
  userId                String
  user                  User                @relation(fields: [userId], references: [id])
  equipmentType         String
  brand                 String?
  model                 String?
  serialNumber          String?
  color                 String?
  physicalCondition     String?
  accessoriesReceived   String?
  reportedIssue         String
  initialDiagnosis      String?
  receptionNotes        String?
  technicalDiagnosis    String?
  solutionApplied       String?
  status                ServiceOrderStatus  @default(RECEIVED)
  estimatedDeliveryDate DateTime?
  receivedAt            DateTime            @default(now())
  deliveredAt           DateTime?
  laborCost             Decimal             @default(0) @db.Decimal(12, 2)
  partsCost             Decimal             @default(0) @db.Decimal(12, 2)
  discount              Decimal             @default(0) @db.Decimal(12, 2)
  total                 Decimal             @default(0) @db.Decimal(12, 2)
  notes                 String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  items                 ServiceOrderItem[]
  logs                  ServiceOrderLog[]
  photos                ServiceOrderPhoto[]
  cashMovements         CashMovement[]
  sunatDocuments        SunatDocument[]
  paymentTransactions   PaymentTransaction[]

  @@index([customerId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model ServiceOrderPhoto {
  id             String       @id @default(uuid())
  serviceOrderId String
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  imageData      String       @db.Text
  fileName       String?
  mimeType       String
  sizeBytes      Int?
  note           String?
  createdAt      DateTime     @default(now())

  @@index([serviceOrderId])
}

model ServiceOrderItem {
  id             String       @id @default(uuid())
  serviceOrderId String
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id])
  productId      String?
  product        Product?     @relation(fields: [productId], references: [id])
  description    String
  quantity       Int
  unitPrice      Decimal      @db.Decimal(12, 2)
  subtotal       Decimal      @db.Decimal(12, 2)
  createdAt      DateTime     @default(now())

  @@index([serviceOrderId])
  @@index([productId])
}

model ServiceOrderLog {
  id             String              @id @default(uuid())
  serviceOrderId String
  serviceOrder   ServiceOrder        @relation(fields: [serviceOrderId], references: [id])
  userId         String
  user           User                @relation(fields: [userId], references: [id])
  previousStatus ServiceOrderStatus?
  newStatus      ServiceOrderStatus?
  action         String
  comment        String?
  createdAt      DateTime            @default(now())

  @@index([serviceOrderId])
  @@index([userId])
}

enum ServiceOrderStatus {
  RECEIVED
  DIAGNOSIS
  IN_PROGRESS
  READY
  DELIVERED
  CANCELLED
}

model CashSession {
  id                 String            @id @default(uuid())
  code               String            @unique
  userId             String
  user               User              @relation(fields: [userId], references: [id])
  openingAmount      Decimal           @db.Decimal(12, 2)
  expectedCashAmount Decimal           @default(0) @db.Decimal(12, 2)
  realCashAmount     Decimal?          @db.Decimal(12, 2)
  difference         Decimal           @default(0) @db.Decimal(12, 2)
  totalSales         Decimal           @default(0) @db.Decimal(12, 2)
  totalExpenses      Decimal           @default(0) @db.Decimal(12, 2)
  totalCash          Decimal           @default(0) @db.Decimal(12, 2)
  totalYape          Decimal           @default(0) @db.Decimal(12, 2)
  totalPlin          Decimal           @default(0) @db.Decimal(12, 2)
  totalTransfer      Decimal           @default(0) @db.Decimal(12, 2)
  status             CashSessionStatus @default(OPEN)
  openedAt           DateTime          @default(now())
  closedAt           DateTime?
  notes              String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  movements          CashMovement[]
  quickServiceSales  QuickServiceSale[]

  @@index([userId])
  @@index([status])
  @@index([openedAt])
}

model CashMovement {
  id                    String           @id @default(uuid())
  cashSessionId         String
  cashSession           CashSession      @relation(fields: [cashSessionId], references: [id])
  userId                String
  user                  User             @relation(fields: [userId], references: [id])
  type                  CashMovementType
  concept               String
  amount                Decimal          @db.Decimal(12, 2)
  paymentMethod         PaymentMethod
  reference             String?
  relatedSaleId         String?
  relatedSale           Sale?            @relation(fields: [relatedSaleId], references: [id])
  relatedServiceOrderId String?
  relatedServiceOrder   ServiceOrder?    @relation(fields: [relatedServiceOrderId], references: [id])
  relatedQuickServiceSaleId String?
  relatedQuickServiceSale QuickServiceSale? @relation(fields: [relatedQuickServiceSaleId], references: [id])
  relatedPurchaseOrderId String?
  relatedPurchaseOrder   PurchaseOrder? @relation(fields: [relatedPurchaseOrderId], references: [id])
  notes                 String?
  createdAt             DateTime         @default(now())

  @@index([cashSessionId])
  @@index([userId])
  @@index([type])
  @@index([paymentMethod])
  @@index([relatedSaleId])
  @@index([relatedServiceOrderId])
  @@index([relatedQuickServiceSaleId])
  @@index([relatedPurchaseOrderId])
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  INCOME
  EXPENSE
  SALE
  SERVICE_PAYMENT
  ADJUSTMENT
}

model QuickServiceCategory {
  id          String         @id @default(uuid())
  name        String         @unique
  description String?
  color       String?
  icon        String?
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  services    QuickService[]
}

model QuickService {
  id          String                 @id @default(uuid())
  categoryId  String
  category    QuickServiceCategory   @relation(fields: [categoryId], references: [id])
  name        String
  description String?
  unit        String
  unitPrice   Decimal                @db.Decimal(12, 2)
  costPrice   Decimal?               @db.Decimal(12, 2)
  isActive    Boolean                @default(true)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  saleItems   QuickServiceSaleItem[]

  @@index([categoryId])
  @@index([name])
}

model QuickServiceSale {
  id               String                 @id @default(uuid())
  code             String                 @unique
  customerId       String?
  customer         Customer?              @relation(fields: [customerId], references: [id])
  userId           String
  user             User                   @relation(fields: [userId], references: [id])
  cashSessionId    String
  cashSession      CashSession            @relation(fields: [cashSessionId], references: [id])
  subtotal         Decimal                @db.Decimal(12, 2)
  discount         Decimal                @default(0) @db.Decimal(12, 2)
  total            Decimal                @db.Decimal(12, 2)
  paymentMethod    PaymentMethod
  paymentReference String?
  status           QuickServiceSaleStatus @default(COMPLETED)
  notes            String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  items            QuickServiceSaleItem[]
  cashMovements    CashMovement[]
  paymentTransactions PaymentTransaction[]

  @@index([customerId])
  @@index([userId])
  @@index([cashSessionId])
  @@index([status])
  @@index([createdAt])
}

model QuickServiceSaleItem {
  id                 String           @id @default(uuid())
  quickServiceSaleId String
  quickServiceSale   QuickServiceSale @relation(fields: [quickServiceSaleId], references: [id])
  quickServiceId     String?
  quickService       QuickService?    @relation(fields: [quickServiceId], references: [id])
  description        String
  quantity           Int
  unitPrice          Decimal          @db.Decimal(12, 2)
  subtotal           Decimal          @db.Decimal(12, 2)
  createdAt          DateTime         @default(now())

  @@index([quickServiceSaleId])
  @@index([quickServiceId])
}

enum QuickServiceSaleStatus {
  COMPLETED
  CANCELLED
}

model Supplier {
  id             String          @id @default(uuid())
  name           String
  ruc            String?         @unique
  phone          String?
  whatsapp       String?
  email          String?
  address        String?
  department     String?
  province       String?
  district       String?
  reference      String?
  contactName    String?
  contactRole    String?
  sunatStatus    String?
  sunatCondition String?
  notes          String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  purchaseOrders PurchaseOrder[]
  products       SupplierProduct[]

  @@index([name])
  @@index([phone])
  @@index([email])
}

model SupplierProduct {
  id             String    @id @default(uuid())
  supplierId     String
  supplier       Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  productId      String?
  product        Product?  @relation(fields: [productId], references: [id])
  name           String
  category       String?
  unit           String?
  referencePrice Decimal?  @db.Decimal(12, 2)
  deliveryTime   String?
  notes          String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([supplierId])
  @@index([productId])
  @@index([name])
  @@index([category])
}

model PurchaseOrder {
  id            String                @id @default(uuid())
  code          String                @unique
  supplierId    String
  supplier      Supplier              @relation(fields: [supplierId], references: [id])
  userId        String
  user          User                  @relation(fields: [userId], references: [id])
  status        PurchaseOrderStatus   @default(PENDING)
  subtotal      Decimal               @db.Decimal(12, 2)
  taxTotal      Decimal               @db.Decimal(12, 2)
  discount      Decimal               @default(0) @db.Decimal(12, 2)
  total         Decimal               @db.Decimal(12, 2)
  paymentStatus PurchasePaymentStatus @default(PENDING)
  paymentMethod PaymentMethod?
  reference     String?
  expectedDate  DateTime?
  receivedAt    DateTime?
  notes         String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  items         PurchaseOrderItem[]
  cashMovements CashMovement[]

  @@index([supplierId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Int
  receivedQuantity Int          @default(0)
  unitCost        Decimal       @db.Decimal(12, 2)
  subtotal        Decimal       @db.Decimal(12, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([purchaseOrderId])
  @@index([productId])
}

enum PurchaseOrderStatus {
  PENDING
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum PurchasePaymentStatus {
  PENDING
  PAID
  PARTIAL
}

model Notification {
  id            String                 @id @default(uuid())
  userId        String?
  user          User?                  @relation(fields: [userId], references: [id])
  title         String
  message       String
  type          NotificationType       @default(SYSTEM)
  priority      NotificationPriority   @default(MEDIUM)
  isRead        Boolean                @default(false)
  relatedModule String?
  relatedId     String?
  createdAt     DateTime               @default(now())
  readAt        DateTime?

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([priority])
  @@index([createdAt])
}

model BusinessSettings {
  id              String   @id @default(uuid())
  businessName    String
  ruc             String?
  address         String?
  phone           String?
  email           String?
  logoUrl         String?
  currency        String   @default("PEN")
  applyIgv        Boolean  @default(false)
  taxPercentage   Decimal  @default(18) @db.Decimal(5, 2)
  yapeNumber      String?
  plinNumber      String?
  bankAccount     String?
  receiptMessage  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum NotificationType {
  STOCK_LOW
  ORDER_READY
  ORDER_DELAYED
  CASH_DIFFERENCE
  PURCHASE_PENDING
  SYSTEM
}

enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model OnlineOrder {
  id              String              @id @default(uuid())
  code            String              @unique
  customerName    String
  customerPhone   String
  customerEmail   String?
  deliveryAddress String?
  status          OnlineOrderStatus   @default(PENDING)
  subtotal        Decimal             @db.Decimal(12, 2)
  deliveryCost    Decimal             @default(0) @db.Decimal(12, 2)
  total           Decimal             @db.Decimal(12, 2)
  paymentMethod   PaymentMethod?
  paymentStatus   OnlinePaymentStatus @default(PENDING)
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  items           OnlineOrderItem[]

  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

model OnlineOrderItem {
  id            String      @id @default(uuid())
  onlineOrderId String
  onlineOrder   OnlineOrder @relation(fields: [onlineOrderId], references: [id])
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  quantity      Int
  unitPrice     Decimal     @db.Decimal(12, 2)
  subtotal      Decimal     @db.Decimal(12, 2)

  @@index([onlineOrderId])
  @@index([productId])
}

enum OnlineOrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  DELIVERED
  CANCELLED
}

enum OnlinePaymentStatus {
  PENDING
  PAID
  FAILED
}

model IntegrationSetting {
  id             String            @id @default(uuid())
  provider       IntegrationProvider @unique
  mode           IntegrationMode     @default(MOCK)
  status         IntegrationStatus   @default(MOCK)
  isEnabled      Boolean             @default(false)
  publicConfig   Json?
  lastTestAt     DateTime?
  lastTestStatus String?
  lastError      String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model SunatDocument {
  id                     String              @id @default(uuid())
  saleId                 String?
  sale                   Sale?               @relation(fields: [saleId], references: [id])
  serviceOrderId         String?
  serviceOrder           ServiceOrder?       @relation(fields: [serviceOrderId], references: [id])
  documentType           SunatDocumentType
  series                 String
  number                 Int
  customerDocumentType   String
  customerDocumentNumber String
  customerName           String
  subtotal               Decimal             @db.Decimal(12, 2)
  taxTotal               Decimal             @db.Decimal(12, 2)
  total                  Decimal             @db.Decimal(12, 2)
  currency               String              @default("PEN")
  status                 SunatDocumentStatus  @default(DRAFT)
  sunatTicket            String?
  sunatResponseCode      String?
  sunatResponseMessage   String?
  xmlPath                String?
  pdfPath                String?
  cdrPath                String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  @@unique([documentType, series, number])
  @@index([saleId])
  @@index([serviceOrderId])
  @@index([status])
  @@index([createdAt])
}

model WhatsappMessageLog {
  id                String   @id @default(uuid())
  phone             String
  messageType       String
  templateName      String?
  content           String
  status            String
  providerMessageId String?
  errorMessage      String?
  relatedModule     String?
  relatedId         String?
  userId            String?
  user              User?    @relation(fields: [userId], references: [id])
  createdAt         DateTime @default(now())

  @@index([phone])
  @@index([status])
  @@index([relatedModule])
  @@index([userId])
  @@index([createdAt])
}

model PaymentTransaction {
  id                        String                   @id @default(uuid())
  provider                  PaymentProvider
  relatedSaleId             String?
  relatedSale               Sale?                    @relation(fields: [relatedSaleId], references: [id])
  relatedServiceOrderId     String?
  relatedServiceOrder       ServiceOrder?            @relation(fields: [relatedServiceOrderId], references: [id])
  relatedQuickServiceSaleId String?
  relatedQuickServiceSale   QuickServiceSale?        @relation(fields: [relatedQuickServiceSaleId], references: [id])
  amount                    Decimal                  @db.Decimal(12, 2)
  currency                  String                   @default("PEN")
  status                    PaymentTransactionStatus @default(CREATED)
  paymentLink               String?
  providerTransactionId     String?
  providerResponse          Json?
  errorMessage              String?
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt

  @@index([provider])
  @@index([status])
  @@index([relatedSaleId])
  @@index([relatedServiceOrderId])
  @@index([relatedQuickServiceSaleId])
  @@index([createdAt])
}

enum IntegrationProvider {
  SUNAT
  WHATSAPP
  CULQI
  IZIPAY
  AI
  ECOMMERCE
}

enum IntegrationMode {
  MOCK
  SANDBOX
  PRODUCTION
}

enum IntegrationStatus {
  NOT_CONFIGURED
  CONFIGURED
  CONNECTED
  ERROR
  MOCK
}

enum SunatDocumentType {
  BOLETA
  FACTURA
  NOTA_CREDITO
  NOTA_DEBITO
}

enum SunatDocumentStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  ERROR
  MOCK
}

enum PaymentProvider {
  CULQI
  IZIPAY
  MOCK
}

enum PaymentTransactionStatus {
  CREATED
  PENDING
  PAID
  FAILED
  CANCELLED
  MOCK
}
